{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "VocaTest: Backend",
      "type": "shell",
      "command": "npm.cmd start",
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "vocatest"
      }
    },
    {
      "label": "VocaTest: Frontend",
      "type": "shell",
      "command": "npm.cmd run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "vocatest"
      }
    },
    {
      "label": "VocaTest: Iniciar frontend y backend",
      "dependsOn": [
        "VocaTest: Backend",
        "VocaTest: Frontend"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
