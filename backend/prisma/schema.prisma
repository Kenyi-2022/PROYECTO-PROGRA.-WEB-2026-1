// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int     @id @default(autoincrement())
  nombres            String
  apellidos          String
  correo             String  @unique
  contrasena         String
  rol                String  @default("Estudiante")
  ciudad             String?
  tipoColegio        String?
  telefono           String?
  edad               Int?
  sexo               String?
  carreraRecomendada String?
  ultimoIngreso      String?
  activo             Boolean @default(true)
  especialidad       String?
  gradoAcademico     String?
  notificacionesEmail Boolean @default(true)
  recordatorios        Boolean @default(true)
  perfilPublico        Boolean @default(true)

  universidadesFavoritas UniversidadUser[]
  historialTests         HistorialTest[]
  favoritos              Favorito[]
  salasCreadas           Sala[]            @relation("CreadorSala")
  resultadosSala         ResultadoSala[]
}

model Universidad {
  id             Int     @id @default(autoincrement())
  nombre         String
  tipo           String
  ubicacion      String?
  costoMatricula String?
  webOficial     String?

  carreras Carrera[]
  escalas  Escala[]
  logos    Logo[]

  usuariosFavoritos UniversidadUser[]
  favoritos        Favorito[]
}

model Carrera {
  id             Int     @id @default(autoincrement())
  universidad_id Int
  nombre         String
  facultad       String?
  duracion       String?
  creditos       Int?
  descripcion    String?
  planEstudios   String?

  universidad Universidad @relation(fields: [universidad_id], references: [id], onDelete: Cascade)
}

model Escala {
  id             Int     @id @default(autoincrement())
  universidad_id Int
  escala         String
  rango          String?

  universidad Universidad @relation(fields: [universidad_id], references: [id], onDelete: Cascade)
}

model Logo {
  id             Int     @id @default(autoincrement())
  universidad_id Int
  url            String
  descripcion    String?

  universidad Universidad @relation(fields: [universidad_id], references: [id], onDelete: Cascade)
}

model UniversidadUser {
  userId        Int
  universidadId Int
  fechaAgregado DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  universidad Universidad @relation(fields: [universidadId], references: [id], onDelete: Cascade)

  @@id([userId, universidadId])
}

model HistorialTest {
  id        Int      @id @default(autoincrement())
  userId    Int
  resultado String
  fecha     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Favorito {
  id            Int      @id @default(autoincrement())
  userId        Int
  universidadId Int
  fecha         DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  universidad Universidad @relation(fields: [universidadId], references: [id], onDelete: Cascade)

  @@unique([userId, universidadId])
}

model Sala {
  id        Int       @id @default(autoincrement())
  nombre    String
  codigo    String    @unique
  pinHash   String
  activa    Boolean   @default(true)
  creadoEn  DateTime  @default(now())
  cerradoEn DateTime?
  creadorId Int

  creador    User            @relation("CreadorSala", fields: [creadorId], references: [id], onDelete: Cascade)
  resultados ResultadoSala[]

  @@index([creadorId])
  @@index([activa])
}

model ResultadoSala {
  id        Int      @id @default(autoincrement())
  salaId    Int
  userId    Int
  resultado String
  fecha     DateTime @default(now())

  sala Sala @relation(fields: [salaId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([salaId, userId])
  @@index([salaId])
  @@index([userId])
}

model PreguntaTest {
  id       Int     @id @default(autoincrement())
  orden    Int     @unique
  pregunta String
  bloque   String
  opciones Json
  activa   Boolean @default(true)
}

model AreaVocacional {
  codigo             String @id
  carreraRecomendada String
}
